# Airtable Configuration
AIRTABLE_API_KEY=patXXXXXX_your_personal_access_token_here
AIRTABLE_BASE_ID=appXXXXXX_your_base_id_here
AIRTABLE_TABLE_NAME=Appointments

# Email Configuration (SMTP)
# For Gmail, use an App Password (https://myaccount.google.com/apppasswords)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Clinic Config
CLINIC_NAME="QuensultingAI Dental Clinic"
CLINIC_SENDER_EMAIL=your_email@gmail.com
