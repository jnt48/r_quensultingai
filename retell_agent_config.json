                                            {
                                                "instruction":  {
                                                                    "type":  "prompt",
                                                                    "text":  "You are the friendly AI receptionist for QuensultingAI Dental Clinic. Greet the caller warmly and say exactly: \u0027Hello! Thank you for calling QuensultingAI Dental Clinic. I\u0027m your AI receptionist. I can help you book an appointment, answer your questions, or connect you to our team. How can I help you today?\u0027"
                                                                },
                                                "name":  "Welcome",
                                                "edges":  [
                                                              {
                                                                  "destination":  "node-faq",
                                                                  "id":  "edge-welcome-to-faq",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User asks about timings, hours, fees, location, walk-ins, payments, services, emergency, or any general question about the clinic"
                                                                                           }
                                                              },
                                                              {
                                                                  "destination":  "node-collect-service",
                                                                  "id":  "edge-welcome-to-book",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User wants to book, schedule, or make an appointment"
                                                                                           }
                                                              },
                                                              {
                                                                  "destination":  "node-escalate",
                                                                  "id":  "edge-welcome-to-escalate",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User asks to speak to a human, staff member, doctor, or requests a transfer"
                                                                                           }
                                                              },
                                                              {
                                                                  "destination":  "node-fallback",
                                                                  "id":  "edge-welcome-to-fallback",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User says something unclear, off-topic, or the intent is not understood"
                                                                                           }
                                                              }
                                                          ],
                                                "start_speaker":  "agent",
                                                "id":  "start-node-1782911165250",
                                                "type":  "conversation",
                                                "display_position":  {
                                                                         "x":  294,
                                                                         "y":  294
                                                                     }
                                            },
                                            {
                                                "instruction":  {
                                                                    "type":  "prompt",
                                                                    "text":  "You are the receptionist at QuensultingAI Dental Clinic. Answer the caller\u0027s question using ONLY these facts:\n- Working Hours: Monday to Saturday, 9:00 AM to 6:00 PM IST. Closed on Sundays and public holidays.\n- Walk-ins: Yes, walk-in patients are accepted, but booking in advance is recommended.\n- Consultation Fee: General dental consultation is Rs 500. Specialised treatments vary.\n- Location: Pune, Maharashtra.\n- Emergency: Yes, we provide emergency dental appointments during working hours.\n- Payments: Cash, Credit/Debit Cards, and all major UPI platforms (Google Pay, PhonePe, Paytm).\n- Services: Dental Cleaning, Root Canal Treatment, Teeth Whitening, Braces Consultation, Tooth Extraction, General Dental Consultation.\nKeep your answer concise and friendly. After answering, ask: \u0027Is there anything else I can help you with?\u0027"
                                                                },
                                                "name":  "FAQ",
                                                "edges":  [
                                                              {
                                                                  "destination":  "node-collect-service",
                                                                  "id":  "edge-faq-to-book",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User wants to book or schedule an appointment"
                                                                                           }
                                                              },
                                                              {
                                                                  "destination":  "node-faq",
                                                                  "id":  "edge-faq-loop",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User has another question about the clinic"
                                                                                           }
                                                              },
                                                              {
                                                                  "destination":  "node-goodbye",
                                                                  "id":  "edge-faq-to-goodbye",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User says no, thank you, goodbye, or has no further questions"
                                                                                           }
                                                              }
                                                          ],
                                                "start_speaker":  "agent",
                                                "id":  "node-faq",
                                                "type":  "conversation",
                                                "display_position":  {
                                                                         "x":  294,
                                                                         "y":  -282
                                                                     }
                                            },
                                            {
                                                "instruction":  {
                                                                    "type":  "prompt",
                                                                    "text":  "Ask the user which dental service they need. Say: \u0027Great! Which service are you looking for? We offer: Dental Cleaning, Root Canal Treatment, Teeth Whitening, Braces Consultation, Tooth Extraction, and General Dental Consultation.\u0027 Wait for them to name a service. Store it as the selected service."
                                                                },
                                                "name":  "Collect Service",
                                                "edges":  [
                                                              {
                                                                  "destination":  "node-collect-datetime",
                                                                  "id":  "edge-service-to-datetime",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User mentions any dental service or procedure they want"
                                                                                           }
                                                              }
                                                          ],
                                                "start_speaker":  "agent",
                                                "id":  "node-collect-service",
                                                "type":  "conversation",
                                                "display_position":  {
                                                                         "x":  700,
                                                                         "y":  433
                                                                     }
                                            },
                                            {
                                                "instruction":  {
                                                                    "type":  "prompt",
                                                                    "text":  "Ask the user for their preferred appointment date and time. Say: \u0027What date and time would you prefer for your appointment? We are open Monday to Saturday, from 9 AM to 6 PM.\u0027 Listen carefully and remember both the date and the time they say."
                                                                },
                                                "name":  "Collect Date and Time",
                                                "edges":  [
                                                              {
                                                                  "destination":  "node-collect-name",
                                                                  "id":  "edge-datetime-to-name",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User provides a date and/or time for their appointment"
                                                                                           }
                                                              }
                                                          ],
                                                "start_speaker":  "agent",
                                                "id":  "node-collect-datetime",
                                                "type":  "conversation",
                                                "display_position":  {
                                                                         "x":  1050,
                                                                         "y":  433
                                                                     }
                                            },
                                            {
                                                "instruction":  {
                                                                    "type":  "prompt",
                                                                    "text":  "Ask the user for their full name. Say: \u0027Could I please get your full name for the appointment?\u0027 Listen and remember their name exactly as they say it."
                                                                },
                                                "name":  "Collect Name",
                                                "edges":  [
                                                              {
                                                                  "destination":  "node-collect-phone",
                                                                  "id":  "edge-name-to-phone",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User provides their name"
                                                                                           }
                                                              }
                                                          ],
                                                "start_speaker":  "agent",
                                                "id":  "node-collect-name",
                                                "type":  "conversation",
                                                "display_position":  {
                                                                         "x":  1400,
                                                                         "y":  433
                                                                     }
                                            },
                                            {
                                                "instruction":  {
                                                                    "type":  "prompt",
                                                                    "text":  "Ask the user for their phone number. Say: \u0027Thank you! And what is the best phone number to reach you on?\u0027 Listen and remember their phone number."
                                                                },
                                                "name":  "Collect Phone",
                                                "edges":  [
                                                              {
                                                                  "destination":  "node-collect-email",
                                                                  "id":  "edge-phone-to-email",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User provides a phone number"
                                                                                           }
                                                              }
                                                          ],
                                                "start_speaker":  "agent",
                                                "id":  "node-collect-phone",
                                                "type":  "conversation",
                                                "display_position":  {
                                                                         "x":  1750,
                                                                         "y":  433
                                                                     }
                                            },
                                            {
                                                "instruction":  {
                                                                    "type":  "prompt",
                                                                    "text":  "Ask the user for their email address for confirmation. Say: \u0027Lastly, could you provide your email address? We will send you a confirmation email with your appointment details and a calendar invite. Or just say skip if you prefer not to share it.\u0027 If they skip, set email to empty string."
                                                                },
                                                "name":  "Collect Email",
                                                "edges":  [
                                                              {
                                                                  "destination":  "node-book-tool",
                                                                  "id":  "edge-email-to-book",
                                                                  "transition_condition":  {
                                                                                               "type":  "prompt",
                                                                                               "prompt":  "User provides an email address or says skip, no thanks, or doesn\u0027t want to share"
                                                                                           }
                                                              }
                                                          ],
                                                "start_speaker":  "agent",
                                                "id":  "node-collect-email",
                                                "type":  "conversation",
                                                "display_position":  {
                                                                         "x":  2100,
                                                                         "y":  433
                                                                     }
                                            },
